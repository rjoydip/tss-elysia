# Authentication
BETTER_AUTH_SECRET=your-secret-key-min-32-chars

# Server Configuration
NODE_ENV=your-environment
HOST=your-host
PORT=3000

# Client Configuration
VITE_API_URL=http://your-host:3000
API_URL=http://your-host:3000/api
BETTER_AUTH_URL=http://your-host:3000/api/auth

# Database Configuration
DATABASE_TYPE=sqlite  # Options: sqlite, postgres

# SQLite Configuration
DATABASE_PATH=your-db-path
DATABASE_NAME=your-db.db

# PostgreSQL Configuration
# Option 1: Full connection URL (recommended for production/replicas)
# Format: postgresql://user:password@host:port/database
POSTGRES_URL=postgresql://tsse:password@localhost:5432/tsse_dev
POSTGRES_REPLICAS=["postgresql://tsse:password@localhost:5433/tsse_dev","postgresql://tsse:password@localhost:5434/tsse_dev"]

# Option 2: Individual connection parameters (used when POSTGRES_URL is not set)
# These are used as fallback to build the primary connection string
POSTGRES_USER=tsse
POSTGRES_PASSWORD=tsse_password
POSTGRES_DB=tsse_dev
POSTGRES_PORT=5432
POSTGRES_HOST=localhost

# Redis Configuration
# Local Docker: redis://localhost:6379
# Upstash:      rediss://default:TOKEN@HOST.upstash.io:6379
REDIS_URL=redis://localhost:6379
