{
  "name": "tss-elysia",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "setup": "bun run scripts/setup.ts",
    "cleanup": "bun run scripts/cleanup.ts",
    "release": "changeset publish",
    "prepare": "simple-git-hooks",
    "postinstall": "[ -d .opencode ] && [ ! -d .opencode/node_modules ] && cd .opencode && bun install || true",
    "build": "bun --bun vite build",
    "dev": "bun --bun vite dev",
    "preview": "bun --bun vite preview",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check .",
    "lint": "oxlint . --format=github",
    "lint:ci": "bun run lint && bun run fmt:check && actions-up",
    "lint:fix": "oxlint . --fix && oxfmt . && actions-up",
    "typecheck": "tsgo --noEmit",
    "react:doctor": "react-doctor . -y",
    "test:unit": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "bun playwright test --ui",
    "test:e2e:headed": "bun playwright test --headed",
    "test:e2e:report": "bun playwright show-report",
    "test:load": ".artifacts/k6 run ./test/load-tests/smoke-test.js",
    "test:load:api": ".artifacts/k6 run ./test/load-tests/api-test.js",
    "test:load:stress": ".artifacts/k6 run ./test/load-tests/stress-test.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "bun run db-seed.ts",
    "db:setup": "bun run scripts/remove-db.ts && bun run db:migrate && bun run db:seed",
    "security": "bun audit --audit-level=critical",
    "changeset": "changeset",
    "changesets": "changeset",
    "version": "changeset version",
    "start": "node .output/server/index.mjs"
  },
  "dependencies": {
    "@elysiajs/eden": "^1.4.8",
    "@elysiajs/openapi": "^1.4.14",
    "@elysiajs/opentelemetry": "^1.4.10",
    "@node-rs/argon2": "^2.0.2",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.214.0",
    "@opentelemetry/sdk-trace-node": "^2.6.1",
    "@tanstack/react-query": "^5.95.2",
    "@tanstack/react-router": "^1.168.8",
    "@tanstack/react-router-devtools": "^1.166.11",
    "@tanstack/react-start": "^1.167.13",
    "better-auth": "^1.5.6",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.28",
    "elysia-rate-limit": "^4.5.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@faker-js/faker": "^10.4.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "^1.3.11",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "^7.0.0-dev.20260329.1",
    "@vitejs/plugin-react": "^6.0.1",
    "actions-up": "^1.12.0",
    "drizzle-kit": "^0.31.10",
    "jsdom": "^29.0.1",
    "k6": "^0.0.0",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "react-doctor": "^0.0.30",
    "simple-git-hooks": "^2.13.1",
    "std-env": "^4.0.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.3"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "simple-git-hooks": {
    "pre-commit": "bun run lint:ci && bun run typecheck && bun run react:doctor"
  },
  "reactDoctor": {
    "ignore": {
      "files": [
        "~/.bun-install-cache/**/*",
        ".e2e/**/*",
        ".opencode/**/*",
        "load-tests/**/*",
        "test/**/*",
        "*.config.ts",
        "k6.config.js"
      ]
    }
  }
}