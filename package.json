{
  "name": "tsse-elysia",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "setup": "bun run ./scripts/setup.ts",
    "cleanup": "bun run ./scripts/cleanup.ts",
    "release": "changeset publish",
    "postinstall": "bunx playwright install",
    "prepare": "simple-git-hooks",
    "proxy:start": "bun --run portless proxy start --https",
    "proxy:foreground": "bun --run portless proxy start --foreground",
    "proxy:stop": "bun --run portless proxy stop --https",
    "build": "bun --bun vite build",
    "dev": "bun --bun vite dev",
    "preview": "bun --bun vite preview",
    "routes:generate": "tsr generate",
    "preview:local": "bun --bun portless run vite preview",
    "frameless:preview": "bunx broz http://localhost:3000",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check .",
    "lint": "oxlint . --format=github",
    "lint:ci": "bun run lint && bun run fmt:check && actions-up",
    "lint:fix": "oxlint . --fix && oxfmt .",
    "typecheck": "tsgo --noEmit",
    "react:doctor": "react-doctor . -y",
    "test:unit": "bun test --preload ./test/setup.ts",
    "test:watch": "bun test --preload ./test/setup.ts --watch",
    "test:coverage": "bun test --preload ./test/setup.ts --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "bun playwright test --ui",
    "test:e2e:headed": "bun playwright test --headed",
    "test:e2e:report": "bun playwright show-report",
    "test:load": "bunx k6 run .k6/smoke-test.js",
    "test:load:api": "bunx k6 run .k6/api-test.js",
    "test:load:stress": "bunx k6 run .k6/stress-test.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "bun run ./scripts/db-seed.ts",
    "db:remove": "bun run ./scripts/remove-db.ts",
    "db:setup": "bun run db:remove && bun run db:push && bun run db:seed",
    "db:reset": "bun run db:remove && bun run db:push",
    "security": "bun audit --audit-level=critical",
    "changeset": "changeset",
    "changesets": "changeset",
    "version": "changeset version",
    "knip": "knip",
    "start": "node ./dist/server/server.js"
  },
  "dependencies": {
    "@cfworker/json-schema": "^4.1.1",
    "@electric-sql/pglite": "^0.4.4",
    "@elysiajs/eden": "^1.4.9",
    "@elysiajs/openapi": "^1.4.14",
    "@elysiajs/opentelemetry": "^1.4.11",
    "@hookform/resolvers": "^5.2.2",
    "@libsql/client": "^0.17.2",
    "@modelcontextprotocol/node": "^2.0.0-alpha.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@modelcontextprotocol/server": "^2.0.0-alpha.2",
    "@node-rs/argon2": "^2.0.2",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.214.0",
    "@opentelemetry/sdk-trace-node": "^2.6.1",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-direction": "^1.1.1",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-form": "^1.29.0",
    "@tanstack/react-query": "^5.99.0",
    "@tanstack/react-router": "^1.168.22",
    "@tanstack/react-router-devtools": "^1.166.13",
    "@tanstack/react-start": "^1.167.41",
    "@tanstack/react-store": "^0.9.3",
    "@tanstack/react-table": "^8.21.3",
    "a11yer": "^0.1.0",
    "better-auth": "^1.6.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "1.1.1",
    "confbox": "^0.2.4",
    "consola": "^3.4.2",
    "date-fns": "^4.1.0",
    "db0": "^0.3.4",
    "drizzle-orm": "^0.45.2",
    "drizzle-seed": "^0.3.1",
    "elysia": "^1.4.28",
    "elysia-rate-limit": "^4.6.0",
    "input-otp": "^1.4.2",
    "ioredis": "^5.10.1",
    "lucide-react": "^1.8.0",
    "pg": "^8.20.0",
    "react": "^19.2.5",
    "react-day-picker": "9.14.0",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.72.1",
    "react-markdown": "^10.1.0",
    "react-top-loading-bar": "^3.0.2",
    "recharts": "^3.8.1",
    "rehype-raw": "^7.0.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.3.0",
    "shiki": "^4.0.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "uncrypto": "^0.1.3",
    "unstorage": "^1.17.5",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@faker-js/faker": "^10.4.0",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-query-devtools": "^5.99.0",
    "@tanstack/router-cli": "^1.166.33",
    "@tanstack/router-plugin": "^1.167.22",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "^1.3.12",
    "@types/hast": "^3.0.4",
    "@types/jsdom": "^28.0.1",
    "@types/mdast": "^4.0.4",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "^7.0.0-dev.20260416.1",
    "@vitejs/plugin-react": "^6.0.1",
    "actions-up": "^1.14.0",
    "broz": "^1.0.1",
    "drizzle-kit": "^0.31.10",
    "fdir": "^6.5.0",
    "jsdom": "^29.0.2",
    "k6": "^0.0.0",
    "knip": "^6.4.1",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.60.0",
    "portless": "^0.10.3",
    "react-doctor": "^0.0.30",
    "simple-git-hooks": "^2.13.1",
    "std-env": "^4.1.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.8"
  },
  "peerDependencies": {
    "typescript": "^6.0.2"
  },
  "simple-git-hooks": {
    "pre-commit": "bun run lint:ci && bun run typecheck && bun run react:doctor"
  },
  "reactDoctor": {
    "lint": false,
    "ignore": {
      "files": [
        "~/.bun-install-cache/**/*",
        ".e2e/**/*",
        "load-tests/**/*",
        "test/**/*",
        "*.config.ts",
        "k6.config.js"
      ]
    }
  }
}