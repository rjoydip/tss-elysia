{
  "name": "tss-elysia",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "setup": "bun run ./scripts/setup.ts",
    "cleanup": "bun run ./scripts/cleanup.ts",
    "release": "changeset publish",
    "postinstall": "bunx playwright install",
    "prepare": "simple-git-hooks",
    "build": "bun --bun vite build",
    "dev": "bun --bun vite dev",
    "preview": "bun --bun vite preview",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check .",
    "lint": "oxlint . --format=github",
    "lint:ci": "bun run lint && bun run fmt:check && actions-up",
    "lint:fix": "oxlint . --fix && oxfmt .",
    "typecheck": "tsgo --noEmit",
    "react:doctor": "react-doctor . -y",
    "test:unit": "bun test --preload ./test/setup.ts",
    "test:watch": "bun test --watch --preload ./test/setup.ts",
    "test:coverage": "bun test --coverage --preload ./test/setup.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "test:load": "./.artifacts/k6 run ./perf/smoke-test.js",
    "test:load:api": "./.artifacts/k6 run ./perf/api-test.js",
    "test:load:stress": "./.artifacts/k6 run ./perf/stress-test.js",
    "db:generate": "bun --bun drizzle-kit generate",
    "db:migrate": "bun --bun drizzle-kit migrate",
    "db:push": "bun --bun drizzle-kit push",
    "db:studio": "bun --bun drizzle-kit studio",
    "db:seed": "bun run ./scripts/db-seed.ts",
    "db:setup": "bun run ./scripts/remove-db.ts && bun run db:migrate && bun run db:seed",
    "db:reset": "bun run scripts/remove-db.ts && bun run db:push",
    "security": "bun audit --audit-level=critical",
    "changeset": "changeset",
    "changesets": "changeset",
    "version": "changeset version",
    "start": "node ./dist/server/server.js"
  },
  "dependencies": {
    "@cfworker/json-schema": "^4.1.1",
    "@elysiajs/eden": "^1.4.9",
    "@elysiajs/openapi": "^1.4.14",
    "@elysiajs/opentelemetry": "^1.4.11",
    "@hookform/resolvers": "^5.2.2",
    "@modelcontextprotocol/node": "^2.0.0-alpha.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@modelcontextprotocol/server": "^2.0.0-alpha.2",
    "@node-rs/argon2": "^2.0.2",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.214.0",
    "@opentelemetry/sdk-trace-node": "^2.6.1",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-form": "^1.29.0",
    "@tanstack/react-query": "^5.99.0",
    "@tanstack/react-router": "^1.168.17",
    "@tanstack/react-router-devtools": "^1.166.13",
    "@tanstack/react-start": "^1.167.30",
    "@tanstack/react-store": "^0.9.3",
    "a11yer": "^0.1.0",
    "better-auth": "^1.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "db0": "^0.3.4",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.28",
    "elysia-rate-limit": "^4.5.1",
    "lucide-react": "^1.8.0",
    "pg": "^8.20.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.72.1",
    "react-markdown": "^10.1.0",
    "rehype-raw": "^7.0.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.2.0",
    "shiki": "^4.0.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "unstorage": "^1.17.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@faker-js/faker": "^10.4.0",
    "@lukeed/uuid": "^2.0.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "^1.3.12",
    "@types/hast": "^3.0.4",
    "@types/jsdom": "^28.0.1",
    "@types/mdast": "^4.0.4",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@typescript/native-preview": "^7.0.0-dev.20260411.1",
    "@vitejs/plugin-react": "^6.0.1",
    "actions-up": "^1.13.0",
    "better-sqlite3": "^12.8.0",
    "drizzle-kit": "^0.31.10",
    "k6": "^0.0.0",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.59.0",
    "react-doctor": "^0.0.30",
    "simple-git-hooks": "^2.13.1",
    "std-env": "^4.0.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "ws": "^8.20.0"
  },
  "peerDependencies": {
    "typescript": "^6.0.2"
  },
  "simple-git-hooks": {
    "pre-commit": "bun run lint:ci && bun run typecheck && bun run react:doctor"
  },
  "reactDoctor": {
    "lint": false,
    "ignore": {
      "files": [
        "~/.bun-install-cache/**/*",
        ".e2e/**/*",
        "load-tests/**/*",
        "test/**/*",
        "*.config.ts",
        "k6.config.js"
      ]
    }
  }
}