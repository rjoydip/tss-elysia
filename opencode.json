{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "@franlol/opencode-md-table-formatter@latest",
    "opencode-helicone-session",
    "opencode-pty",
    "opencode-vibeguard",
    "opencode-wakatime"
  ],
  "permission": {
    "skill": {
      "*": "allow",
      "pr-review": "allow",
      "internal-*": "deny",
      "experimental-*": "ask"
    }
  },
  "instructions": ["CONTRIBUTING.md", ".opencode/rules/*.md"],
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--autoConnect",
        "--user-data-dir=./artifacts/chrome-profile-stable"
      ]
    }
  },
  "lsp": {},
  "agent": {}
}
