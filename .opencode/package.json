{
  "name": "tss-elysia-opencode",
  "version": "0.0.0",
  "description": "OpenCode plugin for TSS Elysia",
  "keywords": [
    "agents",
    "ai-coding",
    "automation",
    "developer-tools",
    "hooks",
    "opencode",
    "plugin",
    "tss-elysia"
  ],
  "license": "MIT",
  "files": [
    "dist",
    "commands",
    "prompts",
    "instructions",
    "opencode.json",
    "README.md"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./plugins": {
      "types": "./dist/plugins/index.d.ts",
      "import": "./dist/plugins/index.js"
    },
    "./tools": {
      "types": "./dist/tools/index.d.ts",
      "import": "./dist/tools/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@opencode-ai/plugin": "1.3.6"
  },
  "devDependencies": {
    "@tailwindcss/language-server": "^0.14.29",
    "opencode-ai": "^1.3.6",
    "typescript-language-server": "^5.1.3",
    "vscode-langservers-extracted": "^4.10.0",
    "yaml-language-server": "^1.21.0"
  }
}