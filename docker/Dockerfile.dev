# =============================================================================
# Development Dockerfile - Optimized for hot reload and fast rebuilds
# =============================================================================
FROM dhi.io/bun:1-alpine3.22@sha256:888082a164cec9cbc842b24845285414635a68290eecf9c6d36100feb9f1a967

WORKDIR /app

# Create non-root user with matching UID/GID first
RUN groupadd -r -g 1000 appgroup 2>/dev/null || true && \
    useradd -r -u 1000 -g appgroup -d /app -s /bin/false appuser 2>/dev/null || true

# Copy package files first (for dependency caching)
COPY package.json bun.lock* ./

# Install all dependencies (including dev)
RUN bun install --frozen-lockfile --ignore-scripts

# Copy source code with proper ownership
COPY --chown=1000:1000 . .

# Ensure correct ownership
RUN chown -R appuser:appgroup /app

# Switch to non-root user
USER appuser

# Environment variables
ENV HOST=0.0.0.0
ENV PORT=3000
ENV NODE_ENV=development

# Expose port
EXPOSE 3000

# Development command with hot reload
CMD ["bun", "run", "dev"]
